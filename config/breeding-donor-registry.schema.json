{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starkstorm.local/schemas/breeding-donor-registry.schema.json",
  "title": "Breeding Pokémon Donor Registry",
  "type": "object",
  "required": ["schema_version", "donors"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "donors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "species", "source_save_id", "generation", "game", "transfer_capabilities"],
        "properties": {
          "id": {"type": "string"},
          "species": {"type": "string"},
          "national_dex": {"type": "integer", "minimum": 1, "maximum": 649},
          "source_save_id": {"type": "string"},
          "generation": {"type": "integer", "minimum": 1, "maximum": 5},
          "game": {"type": "string"},
          "language": {"type": ["string", "null"]},
          "gender": {"enum": ["MALE", "FEMALE", "GENDERLESS", "UNKNOWN"]},
          "shiny": {"type": "boolean", "default": false},
          "breeding_roles": {"type": "array", "uniqueItems": true, "items": {"enum": ["SPECIES_PARENT", "DITTO", "FOREIGN_PARENT", "SHINY_DITTO", "DV_COMPATIBLE_PARENT"]}},
          "transfer_capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "location_hint": {"type": ["string", "null"], "description": "Box/slot hint only; no binary data."},
          "verified": {"type": "boolean", "default": false},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
