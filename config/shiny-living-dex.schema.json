{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://starkstorm.local/schemas/shiny-living-dex.schema.json",
  "title": "StarkStorm Shiny Living Dex State",
  "type": "object",
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"const": 1},
    "entries": {
      "type": "object",
      "patternProperties": {
        "^[1-9][0-9]{0,3}$": {
          "type": "object",
          "required": ["status", "quantity"],
          "properties": {
            "status": {"enum": ["missing", "hunting", "caught"]},
            "quantity": {"type": "integer", "minimum": 0},
            "game": {"type": "string"},
            "save": {"type": "string"},
            "ball": {"type": "string"},
            "apricornBall": {"type": "string"},
            "method": {"type": "string"},
            "date": {"type": "string"},
            "location": {"type": "string"},
            "notes": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "names": {
      "type": "object",
      "patternProperties": {"^[1-9][0-9]{0,3}$": {"type": "string"}},
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
